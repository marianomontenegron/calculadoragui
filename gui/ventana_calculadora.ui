}

/* Campos de texto */
QLineEdit {
    background-color: #ffffff;
    border: 1px solid #dcdfe3;
    border-radius: 6px;
    padding: 6px 8px;
    selection-background-color: #4a90e2;
    selection-color: white;
}

QLineEdit:focus {
    border: 1px solid #4a90e2;
}

/* Botones */
QPushButton {
    background-color: #4a90e2;
    color: white;
    border: none;
    border-radius: 6px;
    padding: 8px 14px;
    font-weight: 500;
}

QPushButton:hover {
    background-color: #3b7dc4;
}

QPushButton:pressed {
    background-color: #2f5f94;
}

QPushButton:disabled {
    background-color: #cfd6dd;
    color: #7a8a99;
}</string>
