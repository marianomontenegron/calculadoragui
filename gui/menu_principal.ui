   <string notr="true">/* ====== Aplicación principal ====== */
QMainWindow {
    background-color: #F5F7FA;
    font-family: &quot;Segoe UI&quot;, &quot;Helvetica Neue&quot;, Arial, sans-serif;
    font-size: 18px;
    color: #2C3E50;
}

/* ====== Barra de menú ====== */
QMenuBar {
    background-color: #FFFFFF;
    border-bottom: 1px solid #DDE3EA;
    padding: 6px;
    font-size: 18px;
}

QMenuBar::item {
    background: transparent;
    padding: 6px 14px;
    margin: 2px;
    border-radius: 4px;
}

QMenuBar::item:selected {
    background-color: #E9EEF5;
}

QMenuBar::item:pressed {
    background-color: #DCE6F2;
}

/* ====== Menú desplegable ====== */
QMenu {
    background-color: #FFFFFF;
    border: 1px solid #DDE3EA;
    padding: 6px;
    font-size: 18px;
}

QMenu::item {
    padding: 8px 28px 8px 20px;
    border-radius: 4px;
}

QMenu::item:selected {
    background-color: #E9EEF5;
    color: #1F2D3D;
}

QMenu::separator {
    height: 1px;
    background: #E0E6ED;
    margin: 6px 12px;
}

/* ====== Acciones ====== */
QMenu::item:disabled {
    color: #A0A7B4;
}

QMenu::indicator {
    width: 16px;
    height: 16px;
}</string>
